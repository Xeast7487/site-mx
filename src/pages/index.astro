---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Maxime Turgeon — Photographe Fitness & Gym à Montréal">
  <Nav lang="fr" />

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-content">
        <p class="hero-eyebrow">Photographe fitness & gym</p>
        <h1>
          <span class="line-1">MAXIME</span>
          <span class="line-2">TURGEON</span>
        </h1>
        <div class="hero-divider"></div>
        <p class="hero-sub">Montréal, QC — Disponible partout au Québec</p>
        <div class="hero-actions">
          <a href="#portfolio" class="btn-primary">Voir le portfolio ↓</a>
          <a href="/contact" class="btn-ghost">Réserver une séance →</a>
        </div>
      </div>
      <div class="hero-scroll">
        <span>SCROLL</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- STATS -->
    <section class="stats-strip">
      <div class="container">
        {[
          { n: '8+', label: 'Années d\'expérience' },
          { n: '500+', label: 'Séances réalisées' },
          { n: '150+', label: 'Clients satisfaits' },
          { n: '4.9★', label: 'Note moyenne' },
        ].map(s => (
          <div class="stat">
            <strong>{s.n}</strong>
            <span>{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- PORTFOLIO -->
    <section class="portfolio" id="portfolio">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">Portfolio</p>
          <h2>Chaque image,<br />une histoire.</h2>
        </div>
        <div class="grid">
          <div class="grid-item gi-1 reveal">
            <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&h=1100&fit=crop&q=80" alt="Séance gym" loading="lazy" />
            <div class="grid-overlay"><span>Séance individuelle</span></div>
          </div>
          <div class="grid-item gi-2 reveal">
            <img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1200&h=700&fit=crop&q=80" alt="Fitness training" loading="lazy" />
            <div class="grid-overlay"><span>Contenu de marque</span></div>
          </div>
          <div class="grid-item gi-3 reveal">
            <img src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?w=700&h=700&fit=crop&q=80" alt="Gym poids" loading="lazy" />
            <div class="grid-overlay"><span>Portrait athlète</span></div>
          </div>
          <div class="grid-item gi-4 reveal">
            <img src="https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?w=700&h=700&fit=crop&q=80" alt="Workout" loading="lazy" />
            <div class="grid-overlay"><span>Entraînement</span></div>
          </div>
          <div class="grid-item gi-5 reveal">
            <img src="https://images.unsplash.com/photo-1526506118085-60ce8714f8c5?w=800&h=1000&fit=crop&q=80" alt="Gym séance" loading="lazy" />
            <div class="grid-overlay"><span>Personal trainer</span></div>
          </div>
          <div class="grid-item gi-6 reveal">
            <img src="https://images.unsplash.com/photo-1549060279-7e168fcee0c2?w=1200&h=700&fit=crop&q=80" alt="Fitness" loading="lazy" />
            <div class="grid-overlay"><span>Événement fitness</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ABOUT TEASER -->
    <section class="about-teaser">
      <div class="container">
        <div class="about-content reveal">
          <p class="eyebrow">À propos</p>
          <h2>Je comprends le sport<br />de l'intérieur.</h2>
          <p>Passionné de fitness depuis toujours, je ne me contente pas de photographier des corps en mouvement — je capture l'effort, l'énergie et la transformation. Avec 8+ ans d'expérience, je travaille avec des athlètes, des entraîneurs et des gyms à travers le Québec.</p>
          <a href="/a-propos" class="link-arrow">Mon parcours →</a>
        </div>
        <div class="about-visual reveal">
          <div class="about-img-wrap">
            <img src="https://images.unsplash.com/photo-1581009146145-b5ef050c2e1e?w=700&h=900&fit=crop&q=80" alt="Maxime Turgeon photographe" />
          </div>
          <div class="about-badge">
            <strong>Montréal</strong>
            <span>Québec, Canada</span>
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="services-teaser">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">Services</p>
          <h2>Ce que je fais.</h2>
        </div>
        <div class="services-grid">
          {[
            { n: '01', title: 'Séance individuelle', desc: 'Pour les athlètes, coaches et sportifs qui veulent des photos professionnelles pour leurs réseaux sociaux et leur portfolio.', href: '/services' },
            { n: '02', title: 'Contenu de marque', desc: 'Pour les gyms, studios et marques de fitness qui ont besoin d\'un contenu visuel cohérent et impactant.', href: '/services' },
            { n: '03', title: 'Événements fitness', desc: 'Compétitions, inaugurations, défis sportifs — je couvre votre événement de A à Z.', href: '/services' },
          ].map(s => (
            <a href={s.href} class="service-card reveal">
              <span class="service-num">{s.n}</span>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <span class="card-arrow">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="testimonials">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">Témoignages</p>
          <h2>Ce qu'ils en disent.</h2>
        </div>
        <div class="testi-grid">
          {[
            { q: 'Maxime a su capturer exactement ce que je cherchais. Les photos sont incroyables, je les utilise sur tous mes réseaux !', name: 'Sarah L.', role: 'Coach fitness, Montréal' },
            { q: 'Le meilleur investissement pour mon business. Mes clients comprennent immédiatement ce que je leur offre grâce aux photos.', name: 'Julien B.', role: 'Personal trainer' },
            { q: 'Professionnel, à l\'écoute, et le résultat dépasse largement nos attentes. On retravaillera avec lui sans hésiter.', name: 'CrossFit Verdun', role: 'Gym, Montréal' },
          ].map(t => (
            <div class="testi-card reveal">
              <div class="testi-stars">★★★★★</div>
              <p>"{t.q}"</p>
              <div class="testi-author">
                <strong>{t.name}</strong>
                <span>{t.role}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container reveal">
        <p class="eyebrow">Prêt à vous démarquer ?</p>
        <h2>Votre prochaine<br />séance commence ici.</h2>
        <p>Consultation gratuite · Réponse en 48h</p>
        <a href="/contact" class="btn-primary btn-large">Réserver maintenant →</a>
      </div>
    </section>
  </main>

  <Footer lang="fr" />
</Layout>

<style>
  main { padding-top: 72px; }

  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 4rem 2rem;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 100%, rgba(240,165,0,0.08) 0%, transparent 70%),
      linear-gradient(180deg, #080808 0%, #0a0a0a 100%);
  }
  .hero-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.015'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .hero-content {
    position: relative;
    text-align: center;
    max-width: 900px;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }
  h1 {
    display: flex;
    flex-direction: column;
    line-height: 0.9;
    letter-spacing: -0.04em;
    font-weight: 900;
    margin-bottom: 1.5rem;
  }
  .line-1 {
    font-size: clamp(5rem, 14vw, 11rem);
    color: var(--white);
  }
  .line-2 {
    font-size: clamp(5rem, 14vw, 11rem);
    color: transparent;
    -webkit-text-stroke: 2px rgba(255,255,255,0.2);
  }
  .hero-divider {
    width: 60px;
    height: 1px;
    background: var(--accent);
    margin: 0 auto 1.5rem;
  }
  .hero-sub {
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .hero-scroll span { font-size: 0.65rem; letter-spacing: 0.2em; color: var(--gray-dim); }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.1); }
  }

  /* BUTTONS */
  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.85rem 1.75rem;
    border-radius: 8px;
    transition: background 0.2s, transform 0.2s;
  }
  .btn-primary:hover { background: var(--accent-dark); transform: translateY(-2px); }
  .btn-primary.btn-large { padding: 1rem 2.5rem; font-size: 0.95rem; }
  .btn-ghost {
    background: transparent;
    color: var(--white);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.85rem 1.75rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.05); }

  /* STATS */
  .stats-strip { background: var(--bg-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .stats-strip .container {
    max-width: 1000px; margin: 0 auto; padding: 2.5rem 2rem;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem;
    text-align: center;
  }
  .stat strong { display: block; font-size: 2.5rem; font-weight: 900; color: var(--accent); letter-spacing: -0.03em; line-height: 1; margin-bottom: 0.3rem; }
  .stat span { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray); }

  /* SECTION COMMON */
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  .eyebrow { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
  .section-header { margin-bottom: 3.5rem; }
  .section-header h2 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -0.03em; line-height: 1.1; }

  /* PORTFOLIO GRID */
  .portfolio { padding: 6rem 2rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 220px;
    gap: 6px;
  }
  .grid-item { position: relative; overflow: hidden; background: var(--bg-2); }
  .grid-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .grid-item:hover img { transform: scale(1.04); }
  .grid-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.8) 100%);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .grid-overlay span { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--white); }
  .grid-item:hover .grid-overlay { opacity: 1; }

  .gi-1 { grid-column: span 4; grid-row: span 3; }
  .gi-2 { grid-column: span 8; grid-row: span 2; }
  .gi-3 { grid-column: span 4; grid-row: span 1; }
  .gi-4 { grid-column: span 4; grid-row: span 1; }
  .gi-5 { grid-column: span 4; grid-row: span 2; }
  .gi-6 { grid-column: span 8; grid-row: span 2; }

  /* ABOUT TEASER */
  .about-teaser { padding: 6rem 2rem; background: var(--bg-2); }
  .about-teaser .container {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
  }
  .about-content h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 900; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 1.25rem; }
  .about-content p { font-size: 0.95rem; color: var(--gray); line-height: 1.8; margin-bottom: 2rem; }
  .link-arrow { font-size: 0.85rem; font-weight: 700; letter-spacing: 0.06em; color: var(--accent); text-transform: uppercase; transition: gap 0.2s; }
  .link-arrow:hover { text-decoration: underline; }
  .about-visual { position: relative; }
  .about-img-wrap { border-radius: 16px; overflow: hidden; aspect-ratio: 3/4; }
  .about-img-wrap img { width: 100%; height: 100%; }
  .about-badge {
    position: absolute;
    bottom: -1rem;
    left: -1rem;
    background: var(--accent);
    color: var(--bg);
    padding: 1rem 1.5rem;
    border-radius: 12px;
  }
  .about-badge strong { display: block; font-size: 1rem; font-weight: 900; }
  .about-badge span { font-size: 0.75rem; font-weight: 600; opacity: 0.7; }

  /* SERVICES TEASER */
  .services-teaser { padding: 6rem 2rem; }
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .service-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.25s, background 0.25s, transform 0.25s;
    cursor: pointer;
  }
  .service-card:hover { border-color: var(--accent); background: var(--bg-3); transform: translateY(-4px); }
  .service-num { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; color: var(--accent); }
  .service-card h3 { font-size: 1.15rem; font-weight: 800; }
  .service-card p { font-size: 0.875rem; color: var(--gray); line-height: 1.7; flex: 1; }
  .card-arrow { font-size: 1.2rem; color: var(--accent); margin-top: auto; }

  /* TESTIMONIALS */
  .testimonials { padding: 6rem 2rem; background: var(--bg-2); }
  .testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .testi-card {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .testi-stars { color: var(--accent); font-size: 0.9rem; letter-spacing: 2px; }
  .testi-card p { font-size: 0.9rem; color: var(--gray); line-height: 1.75; font-style: italic; flex: 1; }
  .testi-author strong { display: block; font-size: 0.875rem; font-weight: 700; color: var(--white); }
  .testi-author span { font-size: 0.78rem; color: var(--accent); }

  /* CTA */
  .cta-section { padding: 8rem 2rem; text-align: center; position: relative; overflow: hidden; }
  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 50% 50%, rgba(240,165,0,0.07) 0%, transparent 70%);
  }
  .cta-section .container { position: relative; }
  .cta-section h2 { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1.05; margin-bottom: 1rem; }
  .cta-section > .container > p { font-size: 0.85rem; color: var(--gray); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 2.5rem; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .about-teaser .container { grid-template-columns: 1fr; gap: 3rem; }
    .about-visual { order: -1; }
    .services-grid { grid-template-columns: 1fr; }
    .testi-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .stats-strip .container { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .grid {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 200px;
    }
    .gi-1, .gi-2, .gi-3, .gi-4, .gi-5, .gi-6 { grid-column: span 1; grid-row: span 1; }
    .gi-1, .gi-5 { grid-row: span 2; }
    .portfolio, .about-teaser, .services-teaser, .testimonials, .cta-section { padding: 4rem 1.25rem; }
  }
  @media (max-width: 480px) {
    .stats-strip .container { grid-template-columns: 1fr 1fr; }
    .grid { grid-template-columns: 1fr; grid-auto-rows: 260px; }
    .gi-1, .gi-5 { grid-row: span 1; }
  }
</style>
